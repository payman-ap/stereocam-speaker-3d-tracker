# ==============================================================================
# Project-Specific Exclusions (multicam-speaker-tracker-3d)
# ==============================================================================

# 1. Camera_Calibration: Ignore all images, only track code and calibration matrices
Camera_Calibration/**/*.jpeg
Camera_Calibration/**/*.png

# 2. Data Folder: Ignore everything except the two specified preprocessed files
data/*
!data/sc4_data_person1_preprocessed.csv
!data/sc4_data_person2_preprocessed.csv

# Explicitly ensure the trash folder, data scripts, and raw subdirectories are handled correctly
data/trash/
data/cam_data_raw/
!data/*.py
!data/ReadMeData.md

